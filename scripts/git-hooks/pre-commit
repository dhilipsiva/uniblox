#!/usr/bin/env bash
# Tracked git pre-commit gate (wired via: git config core.hooksPath scripts/git-hooks).
# The commit boundary is where the full test suite runs — clippy AND tests must pass.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# Self-activate the flake devShell (DECISIONS.md ADR-0010) so fmt/clippy/test run
# under the pinned toolchain; falls back to ambient rustup if unavailable (graceful).
eval "$(direnv export bash 2>/dev/null)" 2>/dev/null || true

echo "[pre-commit] cargo fmt --check"
if ! cargo fmt --check; then
  echo "[pre-commit] FAILED: run 'cargo fmt' and re-stage." >&2
  exit 1
fi

echo "[pre-commit] cargo clippy --all-targets -- -D warnings"
if ! cargo clippy --all-targets -- -D warnings; then
  echo "[pre-commit] FAILED: fix clippy warnings before committing." >&2
  exit 1
fi

echo "[pre-commit] cargo test"
if ! cargo test; then
  echo "[pre-commit] FAILED: fix failing tests before committing." >&2
  exit 1
fi

# Mode-1 (standalone) must run with the networking stack ABSENT (ADR-0030): its
# crate graph carries no transport/replication/matchbox/str0m. The Cargo.toml dep
# list is the human-reviewable proof; this is the automated backstop. (If the
# package is missing, cargo tree emits nothing → the check passes — non-fatal.)
echo "[pre-commit] standalone net-free check (cargo tree)"
if cargo tree -p standalone --edges normal 2>/dev/null \
   | grep -Eq '(^|[^[:alnum:]_-])(transport|replication|matchbox[a-z_]*|str0m|webrtc) v[0-9]'; then
  echo "[pre-commit] FAILED: standalone must stay net-free (no transport/replication/matchbox/str0m)." >&2
  exit 1
fi

echo "[pre-commit] OK"
exit 0
